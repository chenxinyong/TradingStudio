{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "TradingStudio": "Information"
    },
    "Serilog": {
      "MinimumLevel": "Information",
      "WriteTo": [
        { "Name": "Console" },
        {
          "Name": "File",
          "Args": {
            "path": "logs/trading-.log",
            "rollingInterval": "Day",
            "retainedFileCountLimit": 30
          }
        }
      ]
    }
  },

  "Urls": "http://localhost:5199",

  "CTP": {
    "MarketData": {
      "FrontAddress": "tcp://180.168.146.187:10131",
      "BrokerID": "9999",
      "UserID": "your_md_user",
      "Password": "your_md_password"
    },
    "Trading": {
      "FrontAddress": "tcp://180.168.146.187:10130",
      "BrokerID": "9999",
      "UserID": "your_trader_user",
      "Password": "your_trader_password",
      "AppID": "your_app_id",
      "AuthCode": "your_auth_code"
    }
  },

  "Data": {
    "BarDB": "data/bars.db",
    "TickCSV": "data/ticks",
    "DuckDB": "data/duckdb"
  },

  "Strategies": {
    "ConfigPath": "configs/strategies",
    "AutoReload": true,
    "ReloadTime": "08:00"
  },

  "Risk": {
    "MaxDailyLoss": 0.05,
    "MaxTotalExposure": 0.80,
    "MaxPositionPerInstrument": 5,
    "MaxDrawdownPerStrategy": 0.20
  },

  "Health": {
    "HealthFile": "health.json",
    "CheckIntervalSeconds": 60,
    "MaxReconnectBackoffSeconds": 120
  }
}
