<Window x:Class="TradingStudio.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:converters="clr-namespace:TradingStudio.UI.Converters"
        Title="TradingStudio — K线图表 Demo (OxyPlot)"
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <!-- ============================================================
         窗口级资源
         ============================================================ -->
    <Window.Resources>
        <converters:RunningToIconConverter x:Key="RunningToIcon" />
        <converters:RunningToTextConverter x:Key="RunningToText" />

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="#3B3B5C" />
            <Setter Property="Foreground" Value="#CDD6F4" />
            <Setter Property="BorderBrush" Value="#585B70" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#585B70" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E1E2E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#A6ADC8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="StatusBar" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6C7086" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="12,0" />
        </Style>
    </Window.Resources>

    <!-- ============================================================
         主布局: 工具栏 + 4 窗格 + 状态栏
         ============================================================ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="5*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1.5*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1.5*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1.5*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── 工具栏 ── -->
        <Border Grid.Row="0" Background="#181825" BorderBrush="#313244" BorderThickness="0,0,0,1" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding ToggleRealtimeCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding IsRunning, Converter={StaticResource RunningToIcon}}" />
                            <TextBlock Text=" " />
                            <TextBlock Text="{Binding IsRunning, Converter={StaticResource RunningToText}}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}"
                            Content="重置视图"
                            Command="{Binding ResetViewCommand}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <CheckBox Style="{StaticResource ToggleCheck}"
                              IsChecked="{Binding ShowMA}" Content="MA(5,20,60)" />
                    <CheckBox Style="{StaticResource ToggleCheck}"
                              IsChecked="{Binding ShowBoll}" Content="BOLL(20,2)" />
                    <CheckBox Style="{StaticResource ToggleCheck}"
                              IsChecked="{Binding ShowMACD}" Content="MACD(12,26,9)" />
                    <CheckBox Style="{StaticResource ToggleCheck}"
                              IsChecked="{Binding ShowRSI}" Content="RSI(14)" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource StatusBar}" Text="rb2608 · 1分钟 · 模拟数据" />
                    <TextBlock Style="{StaticResource StatusBar}"
                               Text="{Binding StatusText}" Foreground="#A6ADC8" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 窗格1: K线主图 ── -->
        <oxy:PlotView Grid.Row="1" Model="{Binding KLineModel}" />

        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch"
                      Background="#45475A" />

        <!-- ── 窗格2: 成交量 ── -->
        <oxy:PlotView Grid.Row="3" Model="{Binding VolumeModel}" />

        <GridSplitter Grid.Row="4" Height="4" HorizontalAlignment="Stretch"
                      Background="#45475A" />

        <!-- ── 窗格3: MACD ── -->
        <oxy:PlotView Grid.Row="5" Model="{Binding MacdModel}" />

        <GridSplitter Grid.Row="6" Height="4" HorizontalAlignment="Stretch"
                      Background="#45475A" />

        <!-- ── 窗格4: RSI ── -->
        <oxy:PlotView Grid.Row="7" Model="{Binding RsiModel}" />

        <!-- ── 状态栏 ── -->
        <Border Grid.Row="8" Background="#181825" BorderBrush="#313244" BorderThickness="0,1,0,0" Padding="8,3">
            <TextBlock Style="{StaticResource StatusBar}"
                       Text="K 线 Demo · OxyPlot + MVVM · 完整技术指标 · 实时数据模拟  |  © 2026 TradingStudio" />
        </Border>
    </Grid>
</Window>
